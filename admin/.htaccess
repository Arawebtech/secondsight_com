# ==============================
# BASIC SECURITY
# ==============================
<FilesMatch "^.*(\.htaccess|\.env|\.ini|\.log|\.sh|\.bash)$">
  Require all denied
</FilesMatch>

Options -Indexes

# ==============================
# HTTPS & WWW REDIRECTION
# ==============================
<IfModule mod_rewrite.c>
  RewriteEngine On
# # Allow access to main admin PHP entry points
<FilesMatch "^(index.php|dashboard.php|view-order.php|view-batchcode.php|view-lesson.php|view-batch.php|orderdata.php|toggle_status.php|add-batchcode.php|add-lesson.php|add-batch.php|view-team.php|view-testimonial.php|view-courses.php|view-image.php|view-registration.php|view-blog.php|view-course-comment.php|add-courses.php|change-password.php|add-coupon.php|view-coupon.php|upload-handler.php|userdata.php|add-blog.php|add-credentials.php|add-event.php|add-image.php|add-team.php|add-testimonial.php|fetch_students.php|forgot_password.php|logout.php|view-credentials.php|view-notification.php|add-notification.php|add-reply.php)$">
  Order allow,deny
  Allow from all
</FilesMatch>
  # Force HTTPS + WWW but keep the correct request URI
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\.secondsightfoundation\.com$ [NC]
  RewriteRule ^(.*)$ https://www.secondsightfoundation.com%{REQUEST_URI} [R=301,L]

  # Route /login to index.php
  RewriteRule ^login/?$ index.php [L]

  # Allow all .php files to load normally
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule \.php$ - [L]

  # Fallback to index.php only if file/folder does not exist
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^index\.php$ index.php [L]
</IfModule>

# ==============================
# ERROR DOCUMENTS
# ==============================
ErrorDocument 403 /admin/403.html
ErrorDocument 404 /admin/404.html

# ==============================
# SECURITY HEADERS
# ==============================
<IfModule mod_headers.c>
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ==============================
# GZIP COMPRESSION
# ==============================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# ==============================
# BROWSER CACHING
# ==============================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresDefault "access plus 2 days"
</IfModule>
